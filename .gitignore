# ===== OS junk =====
.DS_Store
Thumbs.db

# ===== Editor / IDE =====
.vscode/
.idea/
*.swp

# ===== Python (in case any task scripts use it) =====
__pycache__/
*.pyc
venv/
.venv/

# ===== Secrets — never commit these =====
.env
*.pem
*.key

# ===== VM images/snapshots (large, don't belong in git) =====
*.ova
*.vdi
*.vmdk

# ===== Logs / temp files (not the named deliverables) =====
*.log
*.tmp
